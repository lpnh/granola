---
source: tests/pretty/src/lib.rs
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A cozy café on the corner of Oak Street and Elm Avenue, pouring coffee and baking sourdough since six every morning."
    />
    <meta
      name="theme-color"
      content="#fbf4e8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1c140d"
      media="(prefers-color-scheme: dark)"
    />
    <title>Oats &amp; Ends Café</title>
    <link
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☕</text></svg>"
      rel="icon"
    />
    <style>
    *, ::after, ::before {
      box-sizing: border-box;
    }
    html {
      -moz-text-size-adjust: none;
      -webkit-text-size-adjust: none;
      text-size-adjust: none;
    }
    body, h1, h2, h3, h4, p, figure, blockquote, dl, dd {
      margin-block-end: 0;
    }
    ul[role="list"], ol[role="list"] {
      list-style: none;
    }
    body {
      min-height: 100vh;
      line-height: 1.5;
    }
    h1, h2, h3, h4, button, input, label {
      line-height: 1.1;
    }
    h1, h2, h3, h4 {
      text-wrap: balance;
    }
    a:not([class]) {
      text-decoration-skip-ink: auto;
      color: currentcolor;
    }
    img, picture {
      max-width: 100%;
      display: block;
    }
    button, input, select, textarea {
      font-family: inherit;
      font-size: inherit;
    }
    textarea:not([rows]) {
      min-height: 10em;
    }
    :target {
      scroll-margin-block: 5ex;
    }
    :root {
      --color-background: #fbf4e8;
      --color-surface: #ffffff;
      --color-border: #e4d3b6;
      --color-text: #2c1c12;
      --color-primary: #96491f;
      --color-primary-text: #fffaf5;
      --color-error: #9a2f22;
      --color-success: #2f6b46;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --color-background: #1c140d;
        --color-surface: #271c13;
        --color-border: #4a3823;
        --color-text: #f3e7d6;
        --color-primary: #e2905c;
        --color-primary-text: #221207;
        --color-error: #e2897d;
        --color-success: #83c99b;
      }
    }
    .btn {
      display: inline flex;
      align-items: center;
      justify-content: center;
      padding: 0.6em 1.2em;
      height: var(--btn-size);
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1.25rem;
      text-decoration: none;
      white-space: nowrap;
      border: 1px solid;
      border-color: var(--btn-border);
      border-radius: 0.5em;
      background-color: var(--btn-bg);
      color: var(--btn-fg);
      cursor: pointer;
      transition: background-color 150ms ease;
      --btn-size: 2.5rem;
      --btn-bg: var(--btn-color, var(--color-surface));
      --btn-border: color-mix(in oklab, var(--btn-bg), #000 5%);
      --btn-fg: var(--color-text);
    }
    .btn:hover {
      --btn-bg: var(
        --btn-hover-bg,
        color-mix(in oklab, var(--btn-color, var(--color-surface)), #000 7%)
      );
    }
    .btn:active {
      --btn-bg: var(
        --btn-active-bg,
        color-mix(in oklab, var(--btn-color, var(--color-surface)), #000 5%)
      );
      --btn-border: var(
        --btn-active-border,
        color-mix(in oklab, var(--btn-color, var(--color-surface)), #000 7%)
      );
      transform: scale(0.97);
    }
    .btn:focus-visible {
      outline-width: 2px;
      outline-style: solid;
      outline-color: var(--btn-color, var(--color-text));
      outline-offset: 2px;
    }
    .btn-primary {
      --btn-color: var(--color-primary);
      --btn-fg: var(--color-primary-text);
    }
    .btn-ghost {
      color: var(--btn-color, var(--color-text));
      --btn-bg: #0000;
      --btn-border: #0000;
      --btn-hover-bg: color-mix(
        in oklab,
        var(--btn-color, var(--color-text)) 10%,
        #0000
      );
      --btn-active-bg: color-mix(
        in oklab,
        var(--btn-color, var(--color-text)) 20%,
        #0000
      );
      --btn-active-border: #0000;
    }
    .btn-square {
      padding: 0;
      width: var(--btn-size);
    }
    .tooltip {
      display: inline flex;
      anchor-scope: all;
      anchor-name: --tip;
    }
    .tip {
      display: inline flex;
      align-items: center;
      justify-content: center;
      width: 1.15rem;
      height: 1.15rem;
      padding: 0;
      border: 1px solid;
      border-color: var(--color-border);
      border-radius: 50%;
      background-color: var(--color-surface);
      color: color-mix(in oklab, var(--color-text) 60%, #0000);
      font-size: 0.7rem;
      font-style: italic;
      font-weight: 700;
      line-height: 1;
      cursor: help;
    }
    .tip:hover, .tip:focus-visible {
      color: var(--color-text);
      border-color: var(--color-primary);
    }
    .tip-bubble {
      display: none;
      opacity: 0;
      transition: opacity 160ms ease, display 160ms allow-discrete;
      position: fixed;
      position-anchor: --tip;
      anchor-name: --tip-bubble;
      position-area: top;
      margin-bottom: 0.5rem;
      position-try-fallbacks: flip-block;
      width: max-content;
      max-width: 20rem;
      padding: 0.25rem 0.5rem;
      border-radius: 0.5rem;
      background-color: var(--color-text);
      color: var(--color-background);
      font-size: 0.8rem;
      font-style: normal;
      font-weight: 400;
      line-height: 1.25;
      text-align: center;
      white-space: normal;
      pointer-events: none;
      z-index: 2;
    }
    .tip-bubble::before {
      content: "";
      z-index: -1;
      position: fixed;
      position-anchor: --tip;
      position-area: top;
      width: 0.6rem;
      height: 0.6rem;
      background-color: var(--color-text);
      transform: rotate(45deg);
      margin-bottom: 0.35rem;
      margin-top: calc(anchor-size(--tip-bubble block) - 0.3rem);
      position-try-fallbacks: flip-block;
    }
    .tooltip:hover .tip-bubble, .tooltip:has(:focus-visible) .tip-bubble {
      display: block;
      opacity: 1;
    }
    @starting-style {
      .tooltip:hover .tip-bubble, .tooltip:has(:focus-visible) .tip-bubble {
        opacity: 0;
      }
    }
    .tooltip-top .tip-bubble {
      position-area: top;
      margin-bottom: 0.5rem;
    }
    .tooltip-bottom .tip-bubble {
      position-area: bottom;
      margin-bottom: 0;
      margin-top: 0.5rem;
    }
    .tooltip-left .tip-bubble {
      position-area: left;
      margin-bottom: 0;
      margin-right: 0.5rem;
      position-try-fallbacks: flip-inline;
    }
    .tooltip-right .tip-bubble {
      position-area: right;
      margin-bottom: 0;
      margin-left: 0.5rem;
      position-try-fallbacks: flip-inline;
    }
    .tooltip-top .tip-bubble::before {
      position-area: top;
      margin-bottom: 0.35rem;
      margin-top: calc(anchor-size(--tip-bubble block) - 0.3rem);
    }
    .tooltip-bottom .tip-bubble::before {
      position-area: bottom;
      margin-top: 0.35rem;
      margin-bottom: calc(anchor-size(--tip-bubble block) - 0.3rem);
    }
    .tooltip-left .tip-bubble::before {
      position-area: left;
      margin-top: 0;
      margin-bottom: 0;
      margin-right: 0.35rem;
      margin-left: calc(anchor-size(--tip-bubble inline) - 0.3rem);
      position-try-fallbacks: flip-inline;
    }
    .tooltip-right .tip-bubble::before {
      position-area: right;
      margin-top: 0;
      margin-bottom: 0;
      margin-left: 0.35rem;
      margin-right: calc(anchor-size(--tip-bubble inline) - 0.3rem);
      position-try-fallbacks: flip-inline;
    }
    body {
      font-family: system-ui, sans-serif;
      color: var(--color-text);
      background-color: var(--color-background);
    }
    h1, h2, h3, h4 {
      font-family: Georgia, "Iowan Old Style", ui-serif, serif;
      font-weight: 600;
    }
    h1 {
      font-size: clamp(2rem, 1.5rem + 2vw, 3.25rem);
    }
    h2 {
      font-size: 1.75rem;
    }
    h3 {
      font-size: 1.25rem;
    }
    .lede {
      max-width: 38rem;
      font-size: 1.125rem;
    }
    .note {
      max-width: 38rem;
      color: color-mix(in oklab, var(--color-text) 70%, transparent);
      font-size: 0.9rem;
    }
    main a:not(.btn), .footer-inner a {
      color: var(--color-primary);
      text-underline-offset: 0.15em;
    }
    ::selection {
      background-color: color-mix(in oklab, var(--color-primary) 30%, transparent);
    }
    .wrap {
      max-width: 68rem;
      margin-inline: auto;
      padding-inline: clamp(1rem, 4vw, 2.5rem);
    }
    .section {
      padding-block: 3rem;
    }
    @media (prefers-reduced-motion: no-preference) {
      html {
        scroll-behavior: smooth;
      }
    }
    .skip-link {
      position: absolute;
      top: -3rem;
      left: 1rem;
      padding: 0.5em 1em;
      border-radius: 0.35em;
      background-color: var(--color-text);
      color: var(--color-background);
      text-decoration: none;
      z-index: 10;
      transition: top 150ms ease;
    }
    .skip-link:focus-visible {
      top: 1rem;
    }
    .site-header {
      border-bottom: 1px solid;
      border-color: var(--color-border);
      position: sticky;
      top: 0;
      z-index: 5;
      background-color: var(--color-background);
    }
    .site-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding-block: 1rem;
    }
    .brand {
      font-family: Georgia, "Iowan Old Style", ui-serif, serif;
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--color-text);
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .nav-links a:not(.btn) {
      color: var(--color-text);
      font-weight: 500;
      text-decoration: none;
    }
    .nav-links a:not(.btn):hover {
      text-decoration: underline;
    }
    .hero {
      padding-block: 4rem 3rem;
      text-align: center;
    }
    .hero .lede {
      max-width: none;
    }
    .hero-actions {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 2rem;
    }
    .menu-groups {
      display: grid;
      gap: 3rem;
      margin-top: 2rem;
    }
    @media (min-width: 720px) {
      .menu-groups {
        grid-template-columns: 1fr 1fr;
      }
    }
    .menu-group h3 {
      border-bottom: 1px solid;
      border-color: var(--color-border);
      padding: 0 0 0.5rem;
      margin-bottom: 1rem;
    }
    .menu-list {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin: 0;
      padding: 0;
    }
    .menu-item {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.25rem 1rem;
    }
    .menu-item-name {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-weight: 600;
    }
    .menu-item-desc {
      flex-basis: 100%;
      color: color-mix(in oklab, var(--color-text) 70%, transparent);
      font-size: 0.9rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1.5rem;
    }
    caption {
      text-align: left;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }
    th, td {
      text-align: left;
      padding: 0.6rem 1rem 0.6rem 0;
      border-bottom: 1px solid;
      border-color: var(--color-border);
      font-variant-numeric: tabular-nums;
    }
    #visit address {
      font-style: normal;
      line-height: 1.7;
      margin-top: 1rem;
    }
    .visit-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }
    #newsletter form {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .field {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .field label {
      font-size: 0.875rem;
      font-weight: 500;
    }
    .field input {
      padding: 0.6em 0.8em;
      border: 1px solid;
      border-color: var(--color-border);
      border-radius: 0.5em;
      background-color: var(--color-surface);
      color: var(--color-text);
      font-size: 1rem;
      min-width: 16rem;
    }
    .field input:focus-visible {
      outline-width: 2px;
      outline-style: solid;
      outline-color: var(--color-primary);
      outline-offset: 2px;
    }
    .site-footer {
      border-top: 1px solid;
      border-color: var(--color-border);
      padding-block: 2rem;
    }
    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .footer-inner address {
      font-style: normal;
      font-size: 0.875rem;
    }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main"
    >Skip to content</a><header class="site-header">
      <nav class="site-nav wrap" aria-label="Primary">
        <a class="brand" href="/">Oats &amp; Ends</a><div class="nav-links">
          <a href="#menu">Menu</a><a href="#hours">Hours</a><a href="#visit"
          >Visit</a><a class="btn btn-primary" href="#newsletter">Newsletter</a>
        </div>
      </nav>
    </header>
    <section class="hero wrap">
      <h1>Freshly roasted, freshly baked</h1>
      <p class="lede">
        We open at six and pour until the last regular leaves. Come for the
        coffee, stay for the toast.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#menu">See the menu</a><a
          class="btn btn-ghost"
          href="#visit"
        >Get directions</a>
      </div>
    </section>
    <main id="main" tabindex="-1">
      <article class="section wrap" id="about">
        <h2>Our story</h2>
        <p>
          Oats &amp; Ends opened on Oak Street, at the corner of Elm Avenue,
          bringing new aromas to the block. Its cozy atmosphere draws in
          passersby looking to treat themselves to a cup or two of good, hot
          black coffee and a slice of something fresh from the oven.
        </p>
      </article>
      <section class="section wrap" id="menu" aria-labelledby="menu-heading">
        <h2 id="menu-heading">On the menu</h2>
        <p class="lede">Small menu, made in-house, changed with the seasons.</p>
        <div class="menu-groups">
          <div class="menu-group">
            <h3>Coffee</h3>
            <ul class="menu-list" role="list">
              <li>
                <span class="menu-item-name"
                >Black coffee</span><p class="menu-item-desc">
                  Drip-brewed, roasted twenty minutes down the road.
                </p>
              </li>
              <li>
                <span class="menu-item-name"
                >Hot chocolate</span><p class="menu-item-desc">
                  Steamed whole milk, dark cocoa, no shortcuts.
                </p>
              </li>
              <li>
                <span class="menu-item-name">Oat milk latte <span
                    class="tooltip tooltip-top"
                  ><button
                      class="tip"
                      type="button"
                      aria-describedby="oat-milk-tip"
                    >
                      i
                    </button><span
                      class="tip-bubble"
                      id="oat-milk-tip"
                      role="tooltip"
                    >Dairy-free. Works in any espresso drink, just
                      ask.</span></span></span><p class="menu-item-desc">
                  Double shot, steamed oat milk.
                </p>
              </li>
            </ul>
          </div>
          <div class="menu-group">
            <h3>From the oven</h3>
            <ul class="menu-list" role="list">
              <li>
                <span class="menu-item-name"
                >Rustic toast</span><p class="menu-item-desc">
                  Thick-cut, butter and jam on the side.
                </p>
              </li>
              <li>
                <span class="menu-item-name"
                >Morning bun</span><p class="menu-item-desc">
                  Laminated dough, cinnamon sugar crust.
                </p>
              </li>
              <li>
                <span class="menu-item-name">Sourdough loaf <span
                    class="tooltip tooltip-top"
                  ><button
                      class="tip"
                      type="button"
                      aria-describedby="sourdough-tip"
                    >
                      i
                    </button><span
                      class="tip-bubble"
                      id="sourdough-tip"
                      role="tooltip"
                    >Baked fresh each morning, ask what's
                      left.</span></span></span><p class="menu-item-desc">
                  Whole loaf, ready to take home.
                </p>
              </li>
            </ul>
          </div>
        </div>
      </section>
      <section class="section wrap" id="hours" aria-labelledby="hours-heading">
        <h2 id="hours-heading">Hours</h2>
        <table>
          <caption>Opening hours</caption>
          <thead>
            <tr>
              <th scope="col">Day</th>
              <th scope="col">Hours</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">Weekdays</th>
              <td>6:00 – 18:00</td>
            </tr>
            <tr>
              <th scope="row">Weekends</th>
              <td>7:00 – 16:00</td>
            </tr>
          </tbody>
        </table>
        <p class="note">
          Holidays are a coin toss. Email us before making a special trip.
        </p>
      </section>
      <section class="section wrap" id="visit" aria-labelledby="visit-heading">
        <h2 id="visit-heading">Visit</h2>
        <address>
          Oak Street, corner of Elm Avenue<br /><a
            href="mailto:hello@oatsandends.test"
          >hello@oatsandends.test</a>
        </address>
        <p class="note">
          No reservations. If there's a free chair, it's yours.
        </p>
        <div class="visit-actions">
          <a class="btn btn-ghost" href="mailto:hello@oatsandends.test"
          >Email us</a>
        </div>
      </section>
      <section
        class="section wrap"
        id="newsletter"
        aria-labelledby="newsletter-heading"
      >
        <h2 id="newsletter-heading">Stay in the loop</h2>
        <p class="lede">
          New seasonal drinks, bread restocks, and the occasional live music
          night, straight to your inbox.
        </p>
        <form action="/newsletter" method="post">
          <div class="field">
            <label for="email">Email</label><input
              id="email"
              type="email"
              name="email"
              autocomplete="email"
              placeholder="you@example.com"
              required
            />
          </div>
          <button class="btn btn-primary">Sign me up</button>
        </form>
        <p class="note">
          Just bread news and the odd event, never more than twice a month.
        </p>
      </section>
    </main>
    <footer class="site-footer">
      <div class="wrap footer-inner">
        <small>&copy; 2026 Oats &amp; Ends Café</small><address>
          Oak Street, corner of Elm Avenue
        </address>
      </div>
    </footer>
  </body>
</html>
