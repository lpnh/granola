---
source: tests/pretty/src/lib.rs
---
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  color: #1a1a1a;
}
.hero {
  padding: 4rem 1rem;
  text-align: center;
  background: linear-gradient(135deg, #f6d365, #fda085);
}
nav a {
  margin-right: 1rem;
  text-decoration: none;
}
@media (min-width: 720px) {
  .menu {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
}
